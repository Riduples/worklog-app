NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, set in Vercel Project Settings (never NEXT_PUBLIC_*, never committed):
# ANTHROPIC_API_KEY=

# Service-role key — required for the PayFast ITN to record a subscription (it
# bypasses RLS, which no signed-in user may). Supabase → Project Settings → API.
# A full-access secret: server-only, never NEXT_PUBLIC_*, never committed.
# SUPABASE_SERVICE_ROLE_KEY=

# PayFast billing. Leave all of these UNSET to run against PayFast's sandbox
# with its public test credentials — the whole flow works before a merchant
# account exists. To go live, set all four:
# PAYFAST_MODE=live
# PAYFAST_MERCHANT_ID=
# PAYFAST_MERCHANT_KEY=
# PAYFAST_PASSPHRASE=
# Optional: the public origin used to build the return/cancel/notify URLs. If
# unset it's taken from the incoming request, which is correct on Vercel.
# NEXT_PUBLIC_SITE_URL=

# Local dev only: point at an installed Chrome for /api/render-pdf.
# Leave unset in production — @sparticuz/chromium supplies the binary.
PUPPETEER_EXECUTABLE_PATH=
